{% from "nhsuk/components/back-link/macro.jinja" import backLink %}
{% from "nhsuk/macros/attributes.jinja" import nhsukAttributes %}

{#- Set variant for this component #}
{%- set variant = params.variant -%}

{#- Set classes for this component #}
{%- set classNames = "nhsuk-breadcrumb" -%}

{%- if variant == "reverse" and (not params.classes or not "nhsuk-breadcrumb--reverse" in params.classes) %}
  {% set classNames = classNames ~ " nhsuk-breadcrumb--" ~ variant %}
{% endif %}

{%- if params.classes %}
  {% set classNames = classNames ~ " " ~ params.classes %}
{% endif -%}

{#- Jinja compatibility - avoid referencing params.items directly
  as it clashes with dict.items() -#}
{%- set items = params.get("items", []) if params else [] -%}

<nav class="{{ classNames }}" {%- if params.id %} id="{{ params.id }}"{% endif %} aria-label="{{ params.labelText | default("Breadcrumb") }}"
  {{- nhsukAttributes(params.attributes) }}>
  <ol class="nhsuk-breadcrumb__list">
{% for item in items %}
  {% if item.href %}
    <li class="nhsuk-breadcrumb__list-item">
      <a class="nhsuk-breadcrumb__link" href="{{ item.href }}" {{- nhsukAttributes(item.attributes) }}>{{ item.text }}</a>
    </li>
  {% endif %}
{% endfor %}
{% if params.href %}
  <li class="nhsuk-breadcrumb__list-item">
    <a class="nhsuk-breadcrumb__link" href="{{ params.href }}">{{ params.text }}</a>
  </li>
  {% set lastHref = params.href %}
  {% set lastText = params.text %}
{% else %}
  {% set lastItem = items | last %}
  {% set lastHref = lastItem.href %}
  {% set lastText = lastItem.text %}
{% endif %}
  </ol>
  {{ backLink({
    "id": params.backLink.id,
    "visuallyHiddenText": params.backLink.visuallyHiddenText if params.backLink.visuallyHiddenText else "Back to",
    "text": params.backLink.text if (params.backLink.html or params.backLink.text) else lastText,
    "html": params.backLink.html if (params.backLink.html or params.backLink.text),
    "href": params.backLink.href if params.backLink.href else lastHref,
    "classes": params.backLink.classes,
    "attributes": params.backLink.attributes if params.backLink.attributes else lastItem.attributes,
    "variant": params.backLink.variant | default(variant),
    "element": params.backLink.element
  }) | indent(2) }}
</nav>
