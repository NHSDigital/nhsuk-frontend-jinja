{% from "nhsuk/components/button/macro.jinja" import button -%}
{% from "nhsuk/components/input/macro.jinja" import input -%}
{% from "nhsuk/macros/icon.jinja" import nhsukIcon %}

{#- Set classes for this component #}
{%- set classNames = "nhsuk-search-input" -%}
{%- set classNamesInput = "nhsuk-search-input__input" -%}
{%- set classNamesInputWrapper = "nhsuk-search-input__wrapper" -%}
{%- set classNamesButton = "nhsuk-search-input__button" -%}

{%- if params.large and (not params.classes or not "nhsuk-search-input--large" in params.classes) %}
  {% set classNames = classNames ~ " nhsuk-search-input--large" %}
{% endif %}

{%- if params.classes %}
  {% set classNamesInput = classNamesInput ~ " " ~ params.classes %}
{% endif %}

{%- if params.button.classes %}
  {% set classNamesButton = classNamesButton ~ " " ~ params.button.classes %}
{% endif %}

{%- if params.inputWrapper.classes %}
  {% set classNamesInputWrapper = classNamesInputWrapper ~ " " ~ params.inputWrapper.classes %}
{% endif %}

{%- if params.formGroup.classes %}
  {% set classNames = classNames ~ " " ~ params.formGroup.classes %}
{% endif %}

{%- set id = params.id if params.id else params.name -%}

{%- set afterInputHtml %}
{% if params.button != "" and params.button is not none and params.button is not false %}
{{ button({
  "html": params.button.html,
  "text": params.button.text,
  "ariaLabel": params.button.ariaLabel | default("Search"),
  "id": params.button.id,
  "href": params.button.href,
  "name": params.button.name,
  "value": params.button.value,
  "type": params.button.type | default("submit", true),
  "icon": params.button.icon | default("search"),
  "small": params.button.small | default(not params.large),
  "preventDoubleClick": params.button.preventDoubleClick,
  "disabled": params.button.disabled | default(params.disabled),
  "classes": classNamesButton,
  "attributes": params.button.attributes,
  "variant": params.button.variant
}) | trim }}
{% endif %}
{% if params.formGroup.afterInput %}
  {{- params.formGroup.afterInput.html | safe | trim if params.formGroup.afterInput.html else params.formGroup.afterInput.text }}
{% endif -%}
{% endset -%}

{{ input({
  "label": params.label,
  "hint": params.hint,
  "errorMessage": params.errorMessage,
  "id": id,
  "name": params.name,
  "value": params.value,
  "placeholder": params.placeholder,
  "type": params.type | default("search"),
  "prefix": params.prefix,
  "suffix": params.suffix,
  "code": params.code,
  "width": params.width,
  "large": params.large,
  "spellcheck": params.spellcheck,
  "inputmode": params.inputmode,
  "autocomplete": params.autocomplete | default("off"),
  "autocapitalize": params.autocapitalize,
  "disabled": params.disabled,
  "describedBy": params.describedBy,
  "classes": classNamesInput,
  "attributes": params.attributes,
  "inputWrapper": {
    "classes": classNamesInputWrapper,
    "attributes": params.inputWrapper.attributes
  },
  "formGroup": {
    "classes": classNames,
    "attributes": params.formGroup.attributes,
    "beforeInput": params.formGroup.beforeInput,
    "afterInput": {
      "html": afterInputHtml
    }
  }
}) | trim }}
